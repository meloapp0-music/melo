# Supabase — client-side config (safe to expose; all access is gated by RLS)
# Copy this file to .env.local and fill in with values from your Supabase
# project dashboard (Project Settings → API).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Ticketmaster Discovery API — powers wishlist upcoming-shows autocomplete
# and the Festivals page. Free key (Consumer Key), no OAuth / domain
# needed. Sign up in ~2 min at https://developer-acct.ticketmaster.com/ —
# create any app, copy the Consumer Key here. 5,000 req/day free tier.
VITE_TICKETMASTER_KEY=your-ticketmaster-consumer-key-here

# Supabase Edge Function: api-proxy
# Server-side CORS proxy for upstreams (Deezer, Setlist.fm, MusicBrainz)
# that don't ship CORS headers. Replaces our dev-time reliance on
# corsproxy.io. Required for production / App Store builds — without it
# we route Setlist.fm traffic through someone else's server, which
# violates their Terms of Service.
#
# Deploy with:
#   supabase functions deploy api-proxy --no-verify-jwt
# Then set this to:
#   https://<your-project-ref>.functions.supabase.co/api-proxy?url=
VITE_API_PROXY_URL=

# Deezer App ID — optional, reserved for future use. Higher API rate
# limits than anonymous access. Register at https://developers.deezer.com/.
VITE_DEEZER_APP_ID=

# =============================================================
# Server-side secrets — DO NOT put these in .env.local!
# These are read inside Supabase Edge Functions only. Set them
# with: supabase secrets set NAME=VALUE
# =============================================================

# MELO_SETTINGS_ENC_KEY
# AES-GCM master key for encrypting per-user Setlist.fm API keys
# at rest. Set once. Rotation requires re-encrypting every row.
# Generate with: openssl rand -base64 48
#   supabase secrets set MELO_SETTINGS_ENC_KEY="<value>"
# Used by: setlistfm-set-key, setlistfm-proxy

# TICKETMASTER_KEY
# Same key as VITE_TICKETMASTER_KEY but server-side. Used by the
# tour-alerts cron Edge Function so it doesn't have to read the
# client-side variable.
#   supabase secrets set TICKETMASTER_KEY="<value>"

# APNS_KEY_ID, APNS_TEAM_ID, APNS_BUNDLE_ID, APNS_AUTH_KEY
# Apple Push Notification credentials for the tour-alerts cron.
# 1. Apple Developer → Keys → create an APNs Auth Key, download .p8
# 2. supabase secrets set \
#      APNS_KEY_ID=XXXXXXXXXX \
#      APNS_TEAM_ID=YYYYYYYYYY \
#      APNS_BUNDLE_ID=com.melo.app \
#      APNS_AUTH_KEY="$(cat AuthKey_XXXXXXXXXX.p8)"
# Optional: APNS_USE_SANDBOX=1 to target the sandbox gateway during dev.

# Schedule the daily cron (one-time):
#   supabase functions deploy tour-alerts --no-verify-jwt
#   supabase functions schedule create tour-alerts --cron "0 17 * * *"
# 17:00 UTC = ~1pm ET / ~10am PT — late enough that everyone outside
# Asia is awake.
